# --- Supabase (PostgreSQL) — même projet que VITE_SUPABASE_URL côté front ---
# Dashboard : Project Settings → Database
# - « Connection string » → URI, ou construire l’URL ci-dessous avec le mot de passe base (pas l’anon key).
# - Si le mot de passe contient des caractères spéciaux (@, #, etc.), l’encoder pour l’URL (RFC 3986).
#
# Format direct (recommandé pour `prisma db push` / migrations) :
#   postgresql://postgres:<MOT_DE_PASSE_DB>@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require
#
# Remplace <PROJECT_REF> par l’identifiant du projet (sous-domaine de *.supabase.co).
# Si le mot de passe contient @ & : / # etc. : l’encoder pour l’URL (sinon erreur Prisma P1013 « invalid port »).

DATABASE_URL="postgresql://postgres:<MOT_DE_PASSE_DB>@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require"

# Redis (BullMQ)
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"

# YouTube Data API v3 — compteur de vues
YOUTUBE_API_KEY=""

# --- TikTok (RapidAPI) ---
TIKTOK_RAPIDAPI_KEY=""
TIKTOK_RAPIDAPI_HOST=""
# TIKTOK_RAPIDAPI_PATH="/api/video/info"
# TIKTOK_RAPIDAPI_QUERY_PARAM="video_url"

# --- Instagram (RapidAPI) ---
INSTAGRAM_RAPIDAPI_KEY=""
INSTAGRAM_RAPIDAPI_HOST=""
# INSTAGRAM_RAPIDAPI_PATH="/api/instagram/media"
# INSTAGRAM_RAPIDAPI_QUERY_PARAM="url"
