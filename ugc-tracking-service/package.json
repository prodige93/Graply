{
  "name": "graply-ugc-tracking-service",
  "private": true,
  "version": "1.0.0",
  "description": "Jobs BullMQ : scraping vues + calcul rémunération UGC (TikTok / Instagram / YouTube)",
  "scripts": {
    "build": "tsc",
    "worker": "tsx src/workers/scraping.worker.ts",
    "dev:worker": "tsx watch src/workers/scraping.worker.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:execute-ugc-sql": "prisma db execute --file prisma/ugc_tables_init.sql --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.3.0",
    "bullmq": "^5.34.0",
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "prisma": "^6.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
