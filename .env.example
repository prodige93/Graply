# Copier vers .env pour le développement local (ne pas committer .env)
#
# OAuth — redirect URI (identique côté Meta / TikTok / Google et dans le code) :
# - Production https://graply.io/ :
#     VITE_OAUTH_REDIRECT_URI=https://graply.io/oauth-redirect.html
#   À déclarer dans : Meta (Instagram), TikTok Login Kit, Google Cloud (YouTube).
# - Défaut si vide : ${VITE_SUPABASE_URL}/storage/v1/object/public/oauth/redirect.html
# - TikTok seul (si Instagram/YouTube restent sur Supabase) : VITE_TIKTOK_OAUTH_REDIRECT_URI=...
#
# Stripe Connect (créateurs) : ajouter dans le Dashboard Stripe les redirect URI :
#   https://graply.io/stripe-callback  (et http://localhost:5173/stripe-callback en dev)
#
# API backend (checkout entreprise) : en prod, VITE_BACKEND_URL = URL où tourne Express
# (ex. https://graply.io si reverse-proxy /api, ou https://api.graply.io).
#
# Build front (Netlify / CI) : proxy /api → Express — même URL que le service Node déployé
# (défaut dans le script : https://api.graply.io). Ex. Render : https://graply-backend.onrender.com
# BACKEND_PUBLIC_URL=https://api.graply.io
#
# Webhooks Meta/Instagram : URL de rappel = <BACKEND_PUBLIC_URL ou VITE_BACKEND_URL>/api/webhooks/meta
# (avec le proxy Netlify : https://graply.io/api/webhooks/meta une fois BACKEND_PUBLIC_URL aligné).
# Verify Token = INSTAGRAM_WEBHOOK_VERIFY_TOKEN côté serveur Express.
VITE_OAUTH_REDIRECT_URI=
VITE_TIKTOK_OAUTH_REDIRECT_URI=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_CONNECT_CLIENT_ID=

# Social OAuth — Client IDs publics (les secrets sont dans Supabase Vault)
# Instagram : mettre l’« Instagram App ID » (écran Instagram → Configuration API avec connexion pro Instagram),
# PAS le jeton « Générer un token » (celui-ci est pour tests manuels / API, pas pour VITE_*).
VITE_INSTAGRAM_CLIENT_ID=
# Instagram (Overview Meta) : produit « Instagram » → API setup with Instagram login — ID d’app Instagram affiché
# dans cette section du Meta App Dashboard. Accès Standard (rôles sur l’app) vs Advanced (App Review + vérif. entreprise).
# Instagram API with Instagram Login — défaut : basic + insights (vues dashboard). Scopes à aligner avec App Review.
# VITE_INSTAGRAM_OAUTH_SCOPES=instagram_business_basic,instagram_business_manage_insights
VITE_TIKTOK_CLIENT_KEY=
# Erreur TikTok « non_sandbox_target » en dev : ajouter le compte TikTok (testeurs / sandbox)
# dans developers.tiktok.com pour cette app, et aligner redirect_uri avec l’URL enregistrée.
# TikTok : défaut côté code = user.info.basic,video.list. Pour forcer basic seul (sandbox) :
# VITE_TIKTOK_OAUTH_SCOPE=user.info.basic
VITE_YOUTUBE_CLIENT_ID=
