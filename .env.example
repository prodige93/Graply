# Copier vers .env pour le développement local (ne pas committer .env)
# OAuth — redirect URI (doit être la MÊME sur Meta, TikTok, Google et dans le code) :
# Option A (défaut) : laisser VITE_OAUTH_REDIRECT_URI vide →
#   ${VITE_SUPABASE_URL}/storage/v1/object/public/oauth/redirect.html
# Option B — toutes plateformes sur une URL (Meta + Google + TikTok) :
#   VITE_OAUTH_REDIRECT_URI=https://graply.netlify.app/oauth-redirect.html
# Option C — TikTok seul sur Netlify, Instagram/YouTube restent sur Supabase (souvent le bon compromis) :
#   VITE_TIKTOK_OAUTH_REDIRECT_URI=https://graply.netlify.app/oauth-redirect.html
VITE_OAUTH_REDIRECT_URI=
VITE_TIKTOK_OAUTH_REDIRECT_URI=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_CONNECT_CLIENT_ID=

# Social OAuth — Client IDs publics (les secrets sont dans Supabase Vault)
VITE_INSTAGRAM_CLIENT_ID=
VITE_TIKTOK_CLIENT_KEY=
VITE_YOUTUBE_CLIENT_ID=
