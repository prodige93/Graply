# Copier vers .env et renseigner les valeurs (ne pas committer .env).

PORT=3300
# Origine du front (Stripe success/cancel, CORS). Prod : https://graply.io
FRONTEND_URL=http://localhost:5173
# Optionnel : plusieurs origines séparées par des virgules (prod + dev + www)
# CORS_ORIGINS=https://graply.io,https://www.graply.io,http://localhost:5173

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Même projet que le front (VITE_SUPABASE_URL)
SUPABASE_URL=https://xxxx.supabase.co
# Dashboard Supabase → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Meta / Instagram — Webhooks (produit « Webhooks » du Meta App Dashboard)
# Callback URL : https://<hôte-backend>/api/webhooks/meta — même valeur que VITE_BACKEND_URL côté front si /api est sur le même domaine.
# META_APP_SECRET = clé secrète de l’application Meta (Paramètres → De base), pas la « Clé secrète Instagram ».
# INSTAGRAM_WEBHOOK_VERIFY_TOKEN = chaîne arbitraire identique à celle saisie dans Meta (Verify Token).
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=
